@model whoshippedit.Controllers.ProfileUpdateViewModel
@{
    ViewData["Title"] = "Update Profile";
}

<div class="w-full max-w-[500px] mx-auto px-6 mt-16 mb-32">
    <!-- HEADER -->
    <div class="mb-10 text-center sm:text-left">
        <h1 class="text-[24px] font-semibold text-primary tracking-tight">Your Profile</h1>
        <p class="text-[13px] text-secondary mt-1">
            Update your details so founders can connect with you.
        </p>
    </div>

    <!-- FORM CARD -->
    <div class="bg-[var(--bg-surface)] border border-[var(--border-default)] rounded-xl p-5 shadow-sm">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="p-3 bg-green-500/10 border border-green-500/20 rounded-lg text-[13px] text-green-400 mb-4 flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post" action="/profile" class="flex flex-col gap-5">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-[13px] text-red-400 mb-2">
                    @Html.ValidationSummary(false, "", new { @class = "ml-4" })
                </div>
            }

            <!-- FIELD 1: Name -->
            <div class="flex flex-col group">
                <label class="text-[12px] font-medium text-secondary mb-1.5 group-focus-within:text-primary transition-colors" for="Name">Full Name</label>
                <input type="text" id="Name" name="Name" value="@Model.Name" maxlength="100" 
                       placeholder="e.g. Jane Doe" 
                       class="w-full h-9 px-3 rounded-lg border border-[var(--border-default)] bg-white/[0.02] text-[13px] text-primary placeholder-white/20 focus:outline-none focus:border-white/30 focus:bg-white/[0.04] transition-all"
                       required />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- FIELD 2: Twitter -->
                <div class="flex flex-col group">
                    <label class="text-[12px] font-medium text-secondary mb-1.5 group-focus-within:text-primary transition-colors" for="TwitterHandle">X (Twitter) Handle</label>
                    <input type="text" id="TwitterHandle" name="TwitterHandle" value="@Model.TwitterHandle" maxlength="50"
                           placeholder="e.g. founder" 
                           class="w-full h-9 px-3 rounded-lg border border-[var(--border-default)] bg-white/[0.02] text-[13px] text-primary placeholder-white/20 focus:outline-none focus:border-white/30 focus:bg-white/[0.04] transition-all" />
                </div>

                <!-- FIELD 3: LinkedIn -->
                <div class="flex flex-col group">
                    <label class="text-[12px] font-medium text-secondary mb-1.5 group-focus-within:text-primary transition-colors" for="LinkedinHandle">LinkedIn Username</label>
                    <input type="text" id="LinkedinHandle" name="LinkedinHandle" value="@Model.LinkedinHandle" maxlength="100"
                           placeholder="e.g. jane-doe-123" 
                           class="w-full h-9 px-3 rounded-lg border border-[var(--border-default)] bg-white/[0.02] text-[13px] text-primary placeholder-white/20 focus:outline-none focus:border-white/30 focus:bg-white/[0.04] transition-all" />
                </div>
            </div>

            <!-- FIELD 4: Bio -->
            <div class="flex flex-col group">
                <label class="text-[12px] font-medium text-secondary mb-1.5 group-focus-within:text-primary transition-colors" for="Bio">Bio</label>
                <textarea id="Bio" name="Bio" rows="3" maxlength="300"
                          placeholder="A short bio about you, what you're building, or your background..."
                          class="w-full p-3 rounded-lg border border-[var(--border-default)] bg-white/[0.02] text-[13px] text-primary placeholder-white/20 focus:outline-none focus:border-white/30 focus:bg-white/[0.04] transition-all resize-none">@Model.Bio</textarea>
            </div>

            <!-- SUBMIT BUTTON -->
            <div class="mt-4 pt-4 border-t border-[var(--border-default)] flex justify-end">
                <button type="submit" class="h-10 px-6 bg-white text-black rounded-lg text-[13px] font-semibold hover:bg-gray-100 transition-all flex items-center justify-center shadow-sm">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
