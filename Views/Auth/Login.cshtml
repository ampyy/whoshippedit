                        <text x="24" y="24" dominant-baseline="central" font-family="Geist" font-size="12" font-weight="500" fill="var(--verified-text)" text-anchor="middle">R</text>

                        <text x="44" y="18.5" dominant-baseline="central" font-family="Geist" font-size="10.5" font-weight="500" fill="var(--text-primary)">Resend</text>
                        
