<!-- ── RIGHT PANEL ────────────────────────────────────────── -->
<main class="auth-right">
    <div class="auth-form-wrap">

        <a href="/" class="auth-mobile-logo">WhoShippedIt</a>

        @if (Model.EmailSent)
        {
            <!-- CHECK EMAIL STATE -->
            <div class="check-email-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--text-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </div>
            <div class="auth-heading">
                <h1>Check your inbox</h1>
                <p>We sent a sign-in link to <strong style="color:var(--text-primary)">@Model.Email</strong>. It expires in 15 minutes and works only once.</p>
            </div>
            <div class="check-email-hint">
                <span style="font-weight:600;color:var(--text-primary);font-size:13px">Didn't get it?</span>
                <span>Check your spam folder, then try resending below.</span>
            </div>
            <form method="post" action="/auth/login">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Email" value="@Model.Email" />
                <button type="submit" class="btn-secondary">Resend sign-in link</button>
            </form>
            <p class="footer-note">
                Wrong email? <a href="/auth/login">Start over</a>
            </p>
        }
        else
        {
            <!-- LOGIN FORM -->
            <div class="auth-heading">
                <h1>Welcome back</h1>
                <p>Sign in to your account or create one — no password needed to start.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="form-error">@Model.ErrorMessage</div>
            }

            <!-- Magic Link -->
            <form method="post" action="/auth/login" style="display:flex;flex-direction:column;gap:14px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />
                <div class="form-group">
                    <label class="form-label" for="magic-email">Email address</label>
                    <input id="magic-email" type="email" name="Email" value="@Model.Email"
                           placeholder="you@example.com" autocomplete="email" required
                           class="form-input" />
                </div>
                <button type="submit" class="btn-primary">
                    Send sign-in link →
                </button>
            </form>

            <div class="divider">or sign in with password</div>

            <!-- Password -->
            <form method="post" action="/auth/login-password" style="display:flex;flex-direction:column;gap:14px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />
                <div class="form-group">
                    <label class="form-label" for="pw-email">Email address</label>
                    <input id="pw-email" type="email" name="Email" value="@Model.Email"
                           placeholder="you@example.com" autocomplete="email"
                           class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="pw-password">Password</label>
                    <input id="pw-password" type="password" name="Password"
                           placeholder="Your password" autocomplete="current-password"
                           class="form-input" />
                </div>
                <button type="submit" class="btn-secondary">Sign in with password</button>
            </form>

            <p class="footer-note">
                By continuing, you agree to our <a href="/terms">Terms</a> and <a href="/privacy">Privacy Policy</a>.
            </p>
        }

    </div>
</main>

</body>
</html>
