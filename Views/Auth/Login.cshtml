                            <rect width="44" height="14" rx="2" fill="var(--bg-subtle)" stroke="var(--border-default)" stroke-width="0.5" />
                            <text x="22" y="7" dominant-baseline="central" font-family="Geist" font-size="7.5" font-weight="400" fill="var(--text-secondary)" text-anchor="middle">Dev Tools</text>
