@model whoshippedit.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Sign in — WhoShippedIt";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function() {
            var t = localStorage.getItem('theme');
            if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Geist', system-ui, -apple-system, sans-serif;
            background: var(--bg-page);
            color: var(--text-primary);
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 480px;
        }

        @@media (max-width: 768px) {
            body { grid-template-columns: 1fr; }
            .auth-left { display: none; }
        }

        /* ── Left panel ── */
        .auth-left {
            background: var(--bg-surface);
            border-right: 1px solid var(--border-default);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 40px;
        }
        .auth-left-logo {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-primary);
            text-decoration: none;
            letter-spacing: -0.3px;
        }
        .auth-left-content {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .auth-left-headline {
            font-size: 26px;
            font-weight: 500;
            color: var(--text-primary);
            line-height: 1.25;
            letter-spacing: -0.5px;
        }
        .auth-left-subheadline {
            font-size: 13px;
            font-weight: 400;
            color: var(--text-secondary);
            line-height: 1.6;
        }
        .auth-left-footer {
            font-size: 11px;
            color: var(--text-tertiary);
        }

        /* ── Right panel ── */
        .auth-right {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 48px;
            background: var(--bg-page);
        }
        .auth-form-wrap {
            width: 100%;
            max-width: 360px;
            display: flex;
            flex-direction: column;
            gap: 28px;
            animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .auth-mobile-logo {
            display: none;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
        }
        @@media (max-width: 768px) {
            .auth-right { padding: 32px 24px; justify-content: flex-start; padding-top: 60px; }
            .auth-mobile-logo { display: block; }
        }

        .auth-heading { display: flex; flex-direction: column; gap: 6px; }
        .auth-heading h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.4px; color: var(--text-primary); }
        .auth-heading p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }

        /* Form group */
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); }
        .form-input {
            width: 100%;
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid var(--border-default);
            background: var(--bg-surface);
            color: var(--text-primary);
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: border-color 0.15s;
        }
        .form-input::placeholder { color: var(--text-tertiary); }
        .form-input:focus { border-color: var(--border-medium); }

        /* Buttons */
        .btn-primary {
            width: 100%;
            padding: 11px 16px;
            border-radius: 10px;
            background: var(--text-primary);
            color: var(--bg-page);
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            border: none;
            cursor: pointer;
            transition: opacity 0.15s, transform 0.1s;
            letter-spacing: -0.1px;
        }
        .btn-primary:hover { opacity: 0.88; }
        .btn-primary:active { transform: scale(0.98); }

        .btn-secondary {
            width: 100%;
            padding: 11px 16px;
            border-radius: 10px;
            background: transparent;
            color: var(--text-primary);
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            border: 1px solid var(--border-default);
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            letter-spacing: -0.1px;
        }
        .btn-secondary:hover { background: var(--bg-hover); }
        .btn-secondary:active { transform: scale(0.98); }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 11px;
            font-weight: 500;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border-default);
        }

        /* Error */
        .form-error {
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid rgba(239, 68, 68, 0.3);
            background: rgba(239, 68, 68, 0.08);
            font-size: 13px;
            color: #f87171;
            line-height: 1.5;
        }

        /* Check email state */
        .check-email-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: var(--bg-surface);
            border: 1px solid var(--border-default);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .check-email-hint {
            display: flex;
            flex-direction: column;
            gap: 6px;
            padding: 14px;
            border-radius: 10px;
            background: var(--bg-surface);
            border: 1px solid var(--border-default);
            font-size: 12px;
            color: var(--text-secondary);
        }

        .footer-note { font-size: 11px; color: var(--text-tertiary); text-align: center; line-height: 1.6; }
        .footer-note a { color: var(--text-secondary); text-decoration: underline; text-underline-offset: 2px; }
        .footer-note a:hover { color: var(--text-primary); }
    </style>
</head>
<body>

