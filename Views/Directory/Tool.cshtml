@Html.AntiForgeryToken()

<script>
    function showReplyBox(commentId) {
        const replyBox = document.getElementById(`reply-box-${commentId}`);
        if (replyBox) {
            replyBox.classList.remove('hidden');
            const textarea = document.getElementById(`reply-input-${commentId}`);
            if (textarea) textarea.focus();
        }
    }

    function hideReplyBox(commentId) {
        const replyBox = document.getElementById(`reply-box-${commentId}`);
        if (replyBox) {
            replyBox.classList.add('hidden');
            const textarea = document.getElementById(`reply-input-${commentId}`);
            if (textarea) textarea.value = '';
        }
    }

    async function submitComment(parentId) {
        const inputId = parentId ? `reply-input-${parentId}` : 'main-comment-input';
        const textarea = document.getElementById(inputId);
        if (!textarea) return;

        const bodyText = textarea.value.trim();
        if (!bodyText) return;

        try {
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenElement) {
                alert("Verification token not found. Please refresh and try again.");
                return;
            }
            const token = tokenElement.value;
            const formData = new URLSearchParams();
            formData.append('__RequestVerificationToken', token);
            formData.append('body', bodyText);
            if (parentId) {
                formData.append('parentId', parentId);
            }

            const response = await fetch(`/directory/tool/@Model.Slug/comment`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: formData.toString()
            });

            if (response.ok) {
                const comment = await response.json();
                insertCommentDOM(comment);
            } else {
                let errText = "Failed to post comment.";
                try {
                    const errData = await response.json();
                    if (errData && errData.error) {
                        errText = errData.error;
                    }
                } catch(e) {}
                alert(errText);
            }
        } catch (error) {
            console.error("Error posting comment:", error);
            alert("An unexpected error occurred while posting your comment.");
        }
    }

    function insertCommentDOM(comment) {
        if (comment.parentId) {
            const parentCommentDiv = document.getElementById(`comment-${comment.parentId}`);
            if (!parentCommentDiv) return;

            const contentCol = parentCommentDiv.querySelector('.flex-col');
            if (!contentCol) return;

            const replyBoxDiv = document.getElementById(`reply-box-${comment.parentId}`);
            
            // Check if replies container already exists
            let repliesDiv = contentCol.querySelector('.border-l-2');
            if (!repliesDiv) {
                repliesDiv = document.createElement('div');
                repliesDiv.className = 'flex flex-col gap-3 mt-3 pl-4 border-l-2 border-default';
                // Insert before the reply box
                contentCol.insertBefore(repliesDiv, replyBoxDiv);
            }

            const replyHTML = `
                <div class="flex gap-3" id="comment-${comment.id}">
                    <div class="w-6 h-6 rounded-full bg-subtle border border-default flex items-center justify-center text-[10px] font-bold text-primary shrink-0 uppercase">
                        ${comment.userInitial}
                    </div>
                    <div class="flex flex-col flex-1 gap-0.5">
                        <div class="flex items-center gap-2">
                            <span class="text-12 font-semibold text-primary">${escapeHtml(comment.userName)}</span>
                            <span class="text-11 text-tertiary">${comment.createdAt}</span>
                        </div>
                        <p class="text-13 text-secondary leading-relaxed">${escapeHtml(comment.body)}</p>
                    </div>
                </div>
            `;
            repliesDiv.insertAdjacentHTML('beforeend', replyHTML);
            
            hideReplyBox(comment.parentId);
        } else {
            const commentsList = document.getElementById('comments-list');
            if (!commentsList) return;

            const noCommentsText = document.getElementById('no-comments-placeholder');
            if (noCommentsText) {
                noCommentsText.remove();
            }

            const commentHTML = `
                <div class="flex gap-3 border-b border-default pb-4 last:border-b-0" id="comment-${comment.id}">
                    <div class="w-8 h-8 rounded-full bg-subtle border border-default flex items-center justify-center text-12 font-bold text-primary shrink-0 uppercase">
                        ${comment.userInitial}
                    </div>
                    <div class="flex flex-col flex-1 gap-1">
                        <div class="flex items-center gap-2">
                            <span class="text-13 font-semibold text-primary">${escapeHtml(comment.userName)}</span>
                            <span class="text-11 text-tertiary">${comment.createdAt}</span>
                            <button onclick="showReplyBox('${comment.id}')" class="text-11 text-secondary hover:text-primary transition-colors ml-2 font-medium">Reply</button>
                        </div>
                        <p class="text-14 text-secondary leading-relaxed">${escapeHtml(comment.body)}</p>
                        
                        <div id="reply-box-${comment.id}" class="hidden mt-3 pl-4 border-l-2 border-default flex flex-col gap-2">
                            <textarea id="reply-input-${comment.id}" rows="2" placeholder="Write a reply..." class="w-full p-2.5 rounded-lg border border-default bg-page text-12 text-primary placeholder:text-tertiary focus:outline-none focus:border-medium transition-colors resize-none shadow-sm"></textarea>
                            <div class="flex justify-end gap-2">
                                <button onclick="hideReplyBox('${comment.id}')" class="px-3 py-1.5 rounded-lg border border-default bg-surface hover:bg-hover text-11 font-medium text-secondary transition-colors">Cancel</button>
                                <button onclick="submitComment('${comment.id}')" class="px-3 py-1.5 rounded-lg bg-primary text-page hover:opacity-90 text-11 font-medium transition-colors">Reply</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            commentsList.insertAdjacentHTML('afterbegin', commentHTML);
            
            const mainInput = document.getElementById('main-comment-input');
            if (mainInput) mainInput.value = '';
        }

        // Update count badge
        const countBadge = document.getElementById('comments-count');
        if (countBadge) {
            const currentCount = parseInt(countBadge.getAttribute('data-count') || '0', 10);
            const newCount = currentCount + 1;
            countBadge.setAttribute('data-count', newCount);
            countBadge.innerText = `Comments (${newCount})`;
        }
    }
    
    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }
</script>

<style>
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
        opacity: 0;
        animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
