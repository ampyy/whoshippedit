<div class="w-full max-w-[1100px] mx-auto px-0 md:px-6 mt-8 mb-20">
    <header class="flex flex-col gap-2 mb-6">
        <div class="flex items-center justify-between gap-4">
            <div>
                <span class="inline-flex items-center gap-1 text-11 font-medium px-2 py-0.5 rounded-full border bg-subtle text-secondary border-default">
                    browse
                </span>
                <h1 class="mt-4 text-22 font-medium leading-[1.3] text-primary">Categories</h1>
            </div>
            <div class="hidden sm:flex items-center gap-2 rounded-md border border-default bg-surface px-3 py-2">
                <span class="text-13 font-medium text-primary">@Model.Count</span>
                <span class="text-12 text-secondary">categories</span>
            </div>
        </div>
        <p class="text-13 leading-[1.7] text-secondary max-w-[620px]">
            Explore the product areas tracked inside WhoBuiltThis. Each category will become a dedicated filtered directory view later.
        </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        @foreach (var category in Model)
        {
            <button type="button"
                    data-category-slug="@category.Slug"
                    class="group text-left bg-surface border border-default rounded-lg overflow-hidden hover:bg-hover hover:border-medium transition-colors cursor-pointer">
                <div class="h-[118px] bg-subtle border-b border-default p-3">
                    @Html.Raw(CategoryArt(category.Slug))
                </div>
                <div class="p-4">
                    <div class="flex items-start justify-between gap-3">
                        <h2 class="text-14 font-medium leading-[1.4] text-primary">@category.Name</h2>
                        <span class="mt-0.5 text-10 text-tertiary">@category.SortOrder.ToString("00")</span>
                    </div>
                    <p class="mt-2 text-12 leading-[1.5] text-secondary">
                        @category.Description
                    </p>
                    <div class="mt-4 inline-flex items-center gap-1.5 text-11 font-medium text-secondary group-hover:text-primary transition-colors">
                        <span>View category</span>
                        <span aria-hidden="true">-></span>
                    </div>
                </div>
            </button>
        }
    </div>
</div>
