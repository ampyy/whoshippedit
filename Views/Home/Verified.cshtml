@{
    ViewData["Title"] = "Verified SaaS";
}

<div class="w-full max-w-[600px] mx-auto px-4 mt-24 mb-32 flex flex-col items-center justify-center text-center">
    <!-- ICON -->
    <div class="w-16 h-16 rounded-2xl bg-[var(--bg-surface)] border border-[var(--border-default)] flex items-center justify-center text-[var(--text-primary)] shadow-sm mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
    </div>

    <!-- TEXT -->
    <h1 class="text-[28px] font-semibold text-primary tracking-tight mb-3">
        Verified SaaS
    </h1>
    <p class="text-[14px] text-secondary max-w-[400px] leading-relaxed mb-8">
        We're building a hand-curated directory of verified SaaS products with real traction, revenue, and active founders.
    </p>

    <!-- BADGE -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-[13px] font-medium text-blue-400">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        Launching in 2 weeks
    </div>
</div>
