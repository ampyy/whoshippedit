@model List<whoshippedit.Models.Product>
@{
    ViewData["Title"] = "Directory";

    var categories = ViewBag.Categories as List<whoshippedit.Models.Category> ?? new List<whoshippedit.Models.Category>();
    var totalCount  = (int)(ViewBag.TotalCount ?? 0);
    var selectedSort = (string)(ViewBag.SelectedSort ?? "latest");
    var selectedCategory = (string)(ViewBag.SelectedCategory ?? "");
    var selectedMrr = (string)(ViewBag.SelectedMrr ?? "");

    // MRR helper: returns (label, cssClasses)
    static (string Label, string Css) MrrBadge(int? mrr)
    {
        if (mrr == null) return ("Unknown", "bg-subtle text-secondary border-default");
        if (mrr < 1000)   return ("$0–$1k MRR",      "bg-subtle text-secondary border-default");
        if (mrr < 10000)  return ("$1k–$10k MRR",    "bg-subtle text-secondary border-default");
        if (mrr < 100000) return ("$10k–$100k MRR",  "bg-mrr-100k-bg text-verified-text border-verified-border");
        if (mrr < 1000000) return ("$100k–$1M MRR",  "bg-mrr-100k-bg text-verified-text border-verified-border");
        return ("$1M+ MRR", "bg-mrr-big-bg text-accent-text border-accent-border");
    }

    static int WouldBuildPct(int yes, int no)
    {
        var total = yes + no;
        return total == 0 ? 0 : (int)Math.Round((double)yes / total * 100);
    }
}

<div class="w-full flex flex-col lg:flex-row items-center justify-center min-h-[65vh] py-12 gap-8 lg:gap-4">
    
    <!-- Left Column: Copy -->
    <div class="w-full lg:w-[45%] flex flex-col justify-center items-start z-10 shrink-0">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-medium bg-surface text-[12px] text-secondary mb-6">
            <span class="flex w-1.5 h-1.5 rounded-full bg-verified"></span>
            @totalCount.ToString("N0")+ products tracked
        </div>

        <!-- Headline -->
        <h1 class="text-[40px] md:text-[56px] leading-[1.05] font-medium tracking-tight text-primary mb-6">
            Discover products.<br/>
            Validate ideas.<br/>
            Build with confidence.
        </h1>

        <!-- Copy -->
        <p class="text-[14px] md:text-[16px] text-secondary leading-relaxed max-w-[480px] mb-8">
            Explore real SaaS products, revenue ranges, competitors, alternatives, and market opportunities. Understand what's already working before investing months building.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
            <a href="/directory" class="w-full sm:w-auto px-6 py-3 rounded-lg bg-[var(--text-primary)] text-[var(--bg-page)] text-[14px] font-medium hover:opacity-90 transition-opacity flex items-center justify-center">
                Explore products
            </a>
            <a href="#" class="w-full sm:w-auto px-6 py-3 rounded-lg bg-[var(--bg-surface)] text-[var(--text-primary)] border border-medium text-[14px] font-medium hover:bg-hover transition-colors flex items-center justify-center">
                Submit your product
            </a>
        </div>
    </div>

    <!-- Right Column: Discovery Ecosystem -->
    <div class="w-full lg:w-[55%] h-[400px] lg:h-[600px] relative flex items-center justify-center overflow-hidden" id="ecosystem-container">
        
        <!-- Subtle Dotted Grid Background with radial fade mask -->
        <div class="absolute inset-0 pointer-events-none opacity-10" 
             style="background-image: radial-gradient(var(--text-primary) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(circle at center, black 30%, transparent 100%); mask-image: radial-gradient(circle at center, black 30%, transparent 100%);">
        </div>

        <!-- Simulated Search Bar UI -->
        <div class="absolute top-8 left-1/2 -translate-x-1/2 z-30 bg-surface/90 backdrop-blur-md border border-medium rounded-full px-4 py-2 flex items-center gap-3 shadow-sm min-w-[280px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-tertiary shrink-0"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <span id="search-text" class="text-[13px] font-mono text-secondary whitespace-nowrap overflow-hidden"></span>
            <span id="search-cursor" class="w-1.5 h-3.5 bg-secondary ml-[-8px]"></span>
        </div>

        <!-- Nodes Container -->
        <div id="nodes-container" class="absolute inset-0 z-10 pointer-events-none"></div>
    </div>

</div>

<!-- Category Quick Links (Marquee) -->
<div class="w-full overflow-hidden relative border-b border-default pb-6 mb-12">
    <!-- Fade edges -->
    <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-page to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-page to-transparent z-10 pointer-events-none"></div>
    
    <div class="flex items-center gap-4 w-max animate-marquee hover:pause">
        @for (int i = 0; i < 4; i++)
        {
            @foreach(var cat in categories.Take(12))
            {
                <a href="/directory/category/@cat.Slug" class="inline-block whitespace-nowrap px-6 py-2 rounded-full border border-default bg-surface hover:bg-hover hover:border-medium text-sm font-medium text-secondary hover:text-primary transition-colors shadow-sm">
                    @cat.Name
                </a>
            }
        }
    </div>
</div>

<!-- Directory Section -->
<div class="w-full max-w-[1100px] mx-auto px-0 md:px-6 mt-12 mb-16 flex flex-col">
    
    <!-- Unified Table Container (Search + List) -->
    <div class="flex flex-col bg-surface border-y md:border md:border-medium rounded-none shadow-sm w-full">
        
        <!-- Search & Filter Header -->
        <form method="get" action="/" id="home-filter-form">
        <div class="p-4 border-b border-medium flex flex-col gap-4">
            <!-- Search Input -->
            <div class="relative w-full h-10">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-tertiary"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input id="home-search" name="search" type="text" value="@ViewBag.Search" placeholder="Search @(totalCount.ToString("N0"))+ products..." class="w-full h-full bg-surface border border-default rounded-lg pl-9 pr-4 text-14 text-primary placeholder-tertiary focus:outline-none focus:border-medium transition-colors" />
            </div>

            <!-- Filters -->
            <div class="flex overflow-x-auto hide-scrollbar gap-2 md:grid md:grid-cols-4 w-full">
                <select id="home-cat" name="category" onchange="document.getElementById('home-filter-form').submit()" class="h-10 bg-surface border border-default hover:border-medium rounded-lg px-3 text-13 text-primary focus:outline-none appearance-none pr-8 cursor-pointer relative transition-colors w-auto shrink-0 min-w-[130px] md:min-w-0 md:w-full" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><polyline points=%226 9 12 15 18 9%22></polyline></svg>'); background-repeat: no-repeat; background-position: right 12px center;">
                    <option value="">Category</option>
                    @foreach (var cat in categories)
                    {
                        if (selectedCategory == cat.Slug)
                        {
                            <option value="@cat.Slug" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Slug">@cat.Name</option>
                        }
                    }
                </select>
                
                <select id="home-mrr" name="mrr" onchange="document.getElementById('home-filter-form').submit()" class="h-10 bg-surface border border-default hover:border-medium rounded-lg px-3 text-13 text-primary focus:outline-none appearance-none pr-8 cursor-pointer transition-colors w-auto shrink-0 min-w-[130px] md:min-w-0 md:w-full" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><polyline points=%226 9 12 15 18 9%22></polyline></svg>'); background-repeat: no-repeat; background-position: right 12px center;">
                    <option value="">Revenue</option>
                    @if (selectedMrr == "0") { <option value="0" selected>Idea (no MRR)</option> } else { <option value="0">Idea (no MRR)</option> }
                    @if (selectedMrr == "1k") { <option value="1k" selected>$0–$1k MRR</option> } else { <option value="1k">$0–$1k MRR</option> }
                    @if (selectedMrr == "10k") { <option value="10k" selected>$1k–$10k MRR</option> } else { <option value="10k">$1k–$10k MRR</option> }
                    @if (selectedMrr == "100k") { <option value="100k" selected>$10k–$100k MRR</option> } else { <option value="100k">$10k–$100k MRR</option> }
                    @if (selectedMrr == "1m") { <option value="1m" selected>$100k–$1M MRR</option> } else { <option value="1m">$100k–$1M MRR</option> }
                    @if (selectedMrr == "big") { <option value="big" selected>$1M+ MRR</option> } else { <option value="big">$1M+ MRR</option> }
                </select>

                <div></div>

                <select id="home-sort" name="sort" onchange="document.getElementById('home-filter-form').submit()" class="h-10 bg-surface border border-default hover:border-medium rounded-lg px-3 text-13 text-primary focus:outline-none appearance-none pr-8 cursor-pointer transition-colors w-auto shrink-0 min-w-[130px] md:min-w-0 md:w-full" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><polyline points=%226 9 12 15 18 9%22></polyline></svg>'); background-repeat: no-repeat; background-position: right 12px center;">
                    @if (selectedSort == "latest") { <option value="latest" selected>Sort: Latest</option> } else { <option value="latest">Sort: Latest</option> }
                    @if (selectedSort == "trending") { <option value="trending" selected>Trending</option> } else { <option value="trending">Trending</option> }
                    @if (selectedSort == "mrr") { <option value="mrr" selected>Highest MRR</option> } else { <option value="mrr">Highest MRR</option> }
                    @if (selectedSort == "upvotes") { <option value="upvotes" selected>Most Upvoted</option> } else { <option value="upvotes">Most Upvoted</option> }
                    @if (selectedSort == "score") { <option value="score" selected>Highest Build Score</option> } else { <option value="score">Highest Build Score</option> }
                </select>
            </div>

            <!-- Results Summary Row -->
            <div class="flex items-center justify-between pt-3 border-t border-default mt-1">
                <span class="text-13 text-primary font-medium px-1">Showing @Model.Count of @totalCount.ToString("N0") products</span>
                <span class="text-12 text-tertiary px-1">Updated daily</span>
            </div>
        </div>
        </form>

        <!-- Product List -->
        <div class="flex flex-col" id="home-product-list">
            @if (Model.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-20 text-center border-b border-default">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-tertiary mb-3"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <h3 class="text-[14px] font-medium text-primary mb-1">No products found</h3>
                    <p class="text-[13px] text-secondary">Try changing your filters or search terms.</p>
                </div>
            }
            else
            {
                @foreach (var prod in Model)
                {
                    var (mrrLabel, mrrCss) = MrrBadge(prod.Mrr);
                    var buildPct = WouldBuildPct(prod.WouldBuildYes, prod.WouldBuildNo);
                    var initial = string.IsNullOrEmpty(prod.Name) ? "?" : prod.Name.Substring(0, 1).ToUpper();
                    <a href="/directory/tool/@prod.Slug" class="group flex items-start gap-3.5 px-4 md:px-5 py-4 md:py-3 border-b border-medium last:border-b-0 hover:bg-hover transition-colors cursor-pointer">
                    
                    <!-- Logo -->
                    <div class="w-8 h-8 md:w-9 md:h-9 shrink-0 bg-subtle border border-medium rounded-md flex items-center justify-center text-base md:text-lg font-medium text-primary mt-0.5 overflow-hidden">
                        @if (!string.IsNullOrEmpty(prod.LogoUrl))
                        {
                            <img src="@prod.LogoUrl" alt="@prod.Name" class="w-full h-full object-cover" loading="lazy" />
                        }
                        else
                        {
                            @initial
                        }
                    </div>

                    <!-- Info Column -->
                    <div class="flex flex-col flex-1 min-w-0">
                        
                        <!-- 1. Name & Badges Row -->
                        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-0.5">
                            <h3 class="text-base md:text-[15px] font-semibold text-primary truncate mr-1">@prod.Name</h3>
                            
                            @if (prod.IsVerified)
                            {
                                <span class="inline-flex items-center gap-1 px-1.5 py-[1px] rounded bg-verified-bg text-verified-text border border-verified-border text-10 uppercase font-semibold tracking-wide">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    Verified
                                </span>
                            }
                            
                            <span class="px-1.5 py-[1px] rounded border text-10 uppercase font-semibold tracking-wide @mrrCss">
                                @mrrLabel
                            </span>

                            @if (!string.IsNullOrEmpty(prod.CategoryName))
                            {
                                <span class="px-1.5 py-[1px] rounded bg-subtle text-secondary border border-default text-10 uppercase font-semibold tracking-wide">
                                    @prod.CategoryName
                                </span>
                            }
                        </div>

                        <!-- 2. Description -->
                        <p class="text-13 md:text-14 text-primary/80 line-clamp-1 md:line-clamp-2 leading-snug mb-1.5 max-w-[800px]">@(prod.Description ?? prod.Tagline)</p>
                        
                        <!-- 3. Metadata & Metrics Row -->
                        <div class="flex flex-wrap items-center justify-between gap-2 mt-auto">
                            <div class="text-11 md:text-12 text-tertiary font-medium">
                                @if (!string.IsNullOrEmpty(prod.FounderName))
                                {
                                    <span>by @prod.FounderName</span>
                                }
                            </div>
                            
                            <div class="flex items-center gap-2 text-11 md:text-12 text-tertiary font-medium">
                                @if (prod.WouldBuildYes + prod.WouldBuildNo > 0)
                                {
                                    <span>@buildPct% would build</span>
                                    <span class="text-border-medium">•</span>
                                }
                                <span class="flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"/><path d="M5 12l7-7 7 7"/></svg>
                                    @prod.UpvoteCount
                                </span>
                            </div>
                        </div>

                    </div>
                </a>
                }
            }
        </div>

    <!-- Load More -->
    <div class="flex justify-center mt-8 pb-16 mb-8">
        <a href="/directory" class="px-6 py-2.5 bg-surface border border-default text-primary rounded-lg text-sm font-medium hover:bg-hover hover:border-medium transition-colors shadow-sm inline-flex items-center justify-center">
            See all products in Directory →
        </a>
    </div>
</div>

</div>

<!-- Platform Ecosystem Tools -->
<div class="w-full max-w-5xl mx-auto px-6 mb-16">
    <div class="flex flex-col gap-2 mb-6">
        <h2 class="text-xl font-semibold text-primary tracking-tight">Platform Toolbox</h2>
        <p class="text-13 text-secondary">Explore advanced tools coming soon to help you analyze, build, and scale your SaaS.</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Card 1: Competitor Comparison Tool -->
        <div class="group flex flex-col bg-surface border border-default hover:border-medium rounded-xl p-5 transition-all hover:shadow-md hover:-translate-y-0.5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="m21 3-7.5 7.5"/><path d="M3 3l7.5 7.5"/><path d="M12 21H3v-5"/><path d="M12 21h9v-5"/></svg>
                </div>
                <span class="px-2 py-0.5 text-[9px] font-bold text-amber-500 bg-amber-500/10 border border-amber-500/20 rounded-md uppercase tracking-wider leading-none">Soon</span>
            </div>
            <h3 class="text-[14px] font-bold text-primary mb-1">Competitor Comparison</h3>
            <p class="text-12 text-secondary leading-relaxed">Side-by-side analysis of product pricing, MRR, tech stacks, and feature offerings.</p>
        </div>

        <!-- Card 2: Build With Me Finder -->
        <div class="group flex flex-col bg-surface border border-default hover:border-medium rounded-xl p-5 transition-all hover:shadow-md hover:-translate-y-0.5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
                <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <span class="px-2 py-0.5 text-[9px] font-bold text-amber-500 bg-amber-500/10 border border-amber-500/20 rounded-md uppercase tracking-wider leading-none">Soon</span>
            </div>
            <h3 class="text-[14px] font-bold text-primary mb-1">"Build With Me" Finder</h3>
            <p class="text-12 text-secondary leading-relaxed">Connect with co-founders, developers, and designers working on similar SaaS projects.</p>
        </div>

        <!-- Card 3: Build in Public Tracker -->
        <div class="group flex flex-col bg-surface border border-default hover:border-medium rounded-xl p-5 transition-all hover:shadow-md hover:-translate-y-0.5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
                <div class="w-8 h-8 rounded-lg bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                </div>
                <span class="px-2 py-0.5 text-[9px] font-bold text-amber-500 bg-amber-500/10 border border-amber-500/20 rounded-md uppercase tracking-wider leading-none">Soon</span>
            </div>
            <h3 class="text-[14px] font-bold text-primary mb-1">Build in Public Tracker</h3>
            <p class="text-12 text-secondary leading-relaxed">Share progress updates, timeline events, and grow your audience directly on the platform.</p>
        </div>

        <!-- Card 4: Submit SaaS -->
        <div class="group flex flex-col bg-surface border border-default hover:border-medium rounded-xl p-5 transition-all hover:shadow-md hover:-translate-y-0.5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
                <div class="w-8 h-8 rounded-lg bg-sky-500/10 border border-sky-500/20 flex items-center justify-center text-sky-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                </div>
                <span class="px-2 py-0.5 text-[9px] font-bold text-amber-500 bg-amber-500/10 border border-amber-500/20 rounded-md uppercase tracking-wider leading-none">Soon</span>
            </div>
            <h3 class="text-[14px] font-bold text-primary mb-1">Submit SaaS</h3>
            <p class="text-12 text-secondary leading-relaxed">List your SaaS directory profile, verify your MRR with Stripe, and get featured instantly.</p>
        </div>
    </div>
</div>

<!-- Categories Grid -->
<div class="w-full max-w-5xl mx-auto px-6 mb-20 mt-12">
    <h2 class="text-xl font-semibold text-primary mb-6 tracking-tight">Explore Categories</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        @foreach(var cat in categories.Take(8))
        {
            <a href="/directory/category/@cat.Slug" class="group flex flex-col bg-page border border-default hover:border-medium rounded-xl overflow-hidden transition-all hover:shadow-md hover:-translate-y-0.5">
                <div class="h-24 w-full relative bg-surface border-b border-default overflow-hidden">
                    <img src="https://picsum.photos/seed/cat-@(cat.Slug)/300/200" alt="@cat.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    <!-- gradient overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                    <h3 class="absolute bottom-3 left-4 text-base font-bold text-white tracking-tight drop-shadow-md">@cat.Name</h3>
                </div>
                <div class="p-4 flex flex-col gap-1.5 flex-1">
                    <p class="text-xs text-secondary line-clamp-2 leading-relaxed">@cat.Description</p>
                </div>
            </a>
        }
    </div>
    
    <!-- Load More Categories -->
    <div class="flex justify-center mt-8">
        <a href="/categories" class="px-6 py-2.5 bg-surface border border-default text-primary rounded-lg text-sm font-medium hover:bg-hover hover:border-medium transition-colors shadow-sm inline-flex items-center justify-center">
            Load more categories
        </a>
    </div>
</div>

<style>
    /* Marquee animation */
    @@keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        animation: marquee 35s linear infinite;
    }
    .hover\:pause:hover {
        animation-play-state: paused;
    }

    /* Blinking cursor animation */
    @@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    .cursor-blink { animation: blink 1s step-end infinite; }
    
    /* Hide scrollbar for mobile filters */
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

@section Scripts {
    <script>
        // Search form submit on Enter
        document.getElementById('home-search')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') document.getElementById('home-filter-form').submit();
        });

        // Ecosystem animation
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('ecosystem-container');
            const nodesContainer = document.getElementById('nodes-container');
            const searchText = document.getElementById('search-text');
            const searchCursor = document.getElementById('search-cursor');
            
            if (!container || !nodesContainer) return;

            // Clustered SaaS queries
            const queries = [
                {
                    text: "> filter: AI tools, MRR > $1M",
                    products: [
                        { name: "Synthia", cat: "AI", mrr: "$10M+", cx: 0.3, cy: 0.3, ox: 0, oy: -50 },
                        { name: "Stackpilot", cat: "AI", mrr: "$1M+", cx: 0.3, cy: 0.3, ox: -70, oy: 40 },
                        { name: "Voicekit", cat: "AI", mrr: "$1M+", cx: 0.3, cy: 0.3, ox: 80, oy: 20 }
                    ]
                },
                {
                    text: "> search: Developer infrastructure",
                    products: [
                        { name: "Deploybase", cat: "Dev Tools", mrr: "$1M+", cx: 0.7, cy: 0.4, ox: 20, oy: -60 },
                        { name: "Authwave", cat: "Dev Tools", mrr: "$1M+", cx: 0.7, cy: 0.4, ox: -60, oy: 30 },
                        { name: "Sendgrid", cat: "Dev Tools", mrr: "$100k+", cx: 0.7, cy: 0.4, ox: 70, oy: 50 }
                    ]
                },
                {
                    text: "> filter: Marketing, category: newsletter",
                    products: [
                        { name: "Letterdrop", cat: "Marketing", mrr: "$1M+", cx: 0.3, cy: 0.75, ox: -40, oy: -30 },
                        { name: "Pingloop", cat: "Marketing", mrr: "$10k+", cx: 0.3, cy: 0.75, ox: 60, oy: -60 },
                        { name: "Formbase", cat: "Marketing", mrr: "$100k+", cx: 0.3, cy: 0.75, ox: 30, oy: 40 }
                    ]
                },
                {
                    text: "> search: Analytics & Data",
                    products: [
                        { name: "Metricflow", cat: "Analytics", mrr: "$1M+", cx: 0.7, cy: 0.75, ox: -40, oy: -30 },
                        { name: "Insightiq", cat: "Analytics", mrr: "$10M+", cx: 0.7, cy: 0.75, ox: 40, oy: 40 }
                    ]
                }
            ];

            const nodes = [];
            const dummyCount = 45;

            for (let i = 0; i < dummyCount; i++) {
                const el = document.createElement('div');
                el.className = 'absolute top-0 left-0 rounded-full transition-opacity duration-1000 ease-out bg-subtle border border-default';
                el.style.width = '6px';
                el.style.height = '6px';
                el.style.opacity = '0.3';
                nodesContainer.appendChild(el);

                nodes.push({
                    el, isDummy: true,
                    cx: Math.random(), cy: Math.random(),
                    ox: (Math.random() - 0.5) * 100,
                    oy: (Math.random() - 0.5) * 100,
                    phaseX: Math.random() * Math.PI * 2,
                    phaseY: Math.random() * Math.PI * 2,
                    speedX: 0.0001 + Math.random() * 0.0001,
                    speedY: 0.0001 + Math.random() * 0.0001,
                    driftX: 10 + Math.random() * 20,
                    driftY: 10 + Math.random() * 20,
                    baseOpacity: 0.15 + Math.random() * 0.2
                });
            }

            queries.forEach((query, qIdx) => {
                query.products.forEach(prod => {
                    const el = document.createElement('div');
                    el.className = 'absolute top-0 left-0 bg-subtle border border-default rounded-full overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] shadow-sm';
                    el.style.width = '6px';
                    el.style.height = '6px';
                    el.style.opacity = '0.3';
                    el.innerHTML = `
                        <div class="inner-content absolute inset-0 p-2.5 w-[140px] flex flex-col gap-1.5 opacity-0 transition-opacity duration-300">
                            <div class="text-[13px] font-medium text-primary whitespace-nowrap overflow-hidden text-ellipsis">${prod.name}</div>
                            <div class="flex items-center gap-1.5">
                                <span class="px-1.5 py-[1px] rounded-sm bg-subtle text-secondary text-[10px] leading-tight border border-default">${prod.cat}</span>
                                <span class="px-1.5 py-[1px] rounded-sm bg-verified-bg text-verified-text text-[10px] leading-tight border border-verified-border">${prod.mrr}</span>
                            </div>
                        </div>
                    `;
                    nodesContainer.appendChild(el);
                    nodes.push({
                        el, isDummy: false, queryIndex: qIdx,
                        cx: prod.cx, cy: prod.cy, ox: prod.ox, oy: prod.oy,
                        phaseX: Math.random() * Math.PI * 2,
                        phaseY: Math.random() * Math.PI * 2,
                        speedX: 0.0001 + Math.random() * 0.0001,
                        speedY: 0.0001 + Math.random() * 0.0001,
                        driftX: 4 + Math.random() * 4,
                        driftY: 4 + Math.random() * 4,
                        baseOpacity: 0.3
                    });
                });
            });

            let activeQueryIndex = -1;

            function animateNodes() {
                const now = Date.now();
                const rect = container.getBoundingClientRect();
                const cw = rect.width, ch = rect.height;
                nodes.forEach(n => {
                    const dx = Math.sin(now * n.speedX + n.phaseX) * n.driftX;
                    const dy = Math.cos(now * n.speedY + n.phaseY) * n.driftY;
                    const x = (cw * n.cx) + n.ox + dx;
                    const y = (ch * n.cy) + n.oy + dy;
                    let elW = 6, elH = 6;
                    if (!n.isDummy && activeQueryIndex === n.queryIndex) { elW = 140; elH = 62; }
                    n.el.style.transform = `translate(${x - elW/2}px, ${y - elH/2}px)`;
                    if (activeQueryIndex !== -1) {
                        n.el.style.opacity = (n.isDummy || n.queryIndex !== activeQueryIndex) ? '0.05' : '1';
                    } else {
                        n.el.style.opacity = n.baseOpacity;
                    }
                });
                requestAnimationFrame(animateNodes);
            }
            animateNodes();

            let sequenceStep = 0;
            async function runSequence() {
                await sleep(1500);
                const q = queries[sequenceStep];
                const targetText = q.text;
                searchCursor.classList.remove('cursor-blink');
                for (let i = 0; i <= targetText.length; i++) {
                    searchText.innerText = targetText.substring(0, i);
                    await sleep(15 + Math.random() * 20);
                }
                searchCursor.classList.add('cursor-blink');
                await sleep(200);
                activeQueryIndex = sequenceStep;
                nodes.forEach(n => {
                    if (!n.isDummy && n.queryIndex === activeQueryIndex) {
                        n.el.style.width = '140px'; n.el.style.height = '62px';
                        n.el.style.borderRadius = '8px';
                        n.el.classList.add('border-medium', 'bg-surface');
                        n.el.classList.remove('border-default', 'bg-subtle');
                        setTimeout(() => { const inner = n.el.querySelector('.inner-content'); if (inner) inner.style.opacity = '1'; }, 150);
                    }
                });
                await sleep(2500);
                nodes.forEach(n => {
                    if (!n.isDummy && n.queryIndex === activeQueryIndex) {
                        const inner = n.el.querySelector('.inner-content');
                        if (inner) inner.style.opacity = '0';
                        n.el.style.width = '6px'; n.el.style.height = '6px';
                        n.el.style.borderRadius = '9999px';
                        n.el.classList.remove('border-medium', 'bg-surface');
                        n.el.classList.add('border-default', 'bg-subtle');
                    }
                });
                activeQueryIndex = -1;
                await sleep(400);
                searchCursor.classList.remove('cursor-blink');
                while (searchText.innerText.length > 0) {
                    searchText.innerText = searchText.innerText.slice(0, -1);
                    await sleep(8);
                }
                searchCursor.classList.add('cursor-blink');
                sequenceStep = (sequenceStep + 1) % queries.length;
                runSequence();
            }
            function sleep(ms) { return new Promise(resolve => setTimeout(resolve, ms)); }
            searchCursor.classList.add('cursor-blink');
            runSequence();
        });
    </script>
}
