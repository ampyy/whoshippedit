@{
    ViewData["Title"] = "Privacy policy";
}

<div class="w-full max-w-[960px] mx-auto px-0 md:px-6 mt-8 mb-20">
    <header class="bg-surface border border-default rounded-lg p-5 md:p-6">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
            <div class="max-w-[680px]">
                <span class="inline-flex items-center gap-1 text-11 font-medium px-2 py-0.5 rounded-full border bg-subtle text-secondary border-default">
                    privacy
                </span>
                <h1 class="mt-4 text-22 font-medium leading-[1.3] text-primary">Privacy policy</h1>
                <p class="mt-3 text-13 leading-[1.7] text-secondary">
                    This policy explains how WhoBuiltThis collects, uses, stores, and protects information when you browse the site, create an account, submit products or ideas, vote, comment, or contact us.
                </p>
            </div>
            <div class="md:min-w-[190px] rounded-md border border-default bg-page p-3">
                <div class="text-11 text-tertiary">Last updated</div>
                <div class="mt-1 text-13 text-primary font-medium">June 7, 2026</div>
                <div class="mt-3 text-11 text-tertiary">Questions</div>
                <a href="mailto:hello@whoshippedit.com" class="mt-1 block text-12 text-link hover:underline">hello@whoshippedit.com</a>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-4 mt-4">
        <aside class="hidden md:block">
            <nav class="sticky top-[84px] bg-surface border border-default rounded-lg p-3">
                <div class="text-11 text-tertiary mb-2 px-2">On this page</div>
                <div class="flex flex-col gap-0.5 text-12">
                    <a href="#overview" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Overview</a>
                    <a href="#information" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Information we collect</a>
                    <a href="#use" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">How we use it</a>
                    <a href="#sharing" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Sharing</a>
                    <a href="#cookies" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Cookies</a>
                    <a href="#retention" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Retention</a>
                    <a href="#rights" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Your choices</a>
                    <a href="#security" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Security</a>
                    <a href="#contact" class="px-2 py-1.5 rounded-md text-secondary hover:text-primary hover:bg-hover transition-colors">Contact</a>
                </div>
            </nav>
        </aside>

        <article class="bg-surface border border-default rounded-lg overflow-hidden">
            <section id="overview" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">1. Overview</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>WhoBuiltThis is a SaaS discovery and idea validation platform. The service helps users discover products, submit products and ideas, vote on validation signals, and understand market activity.</p>
                    <p>We aim to collect only the information needed to run the service, protect the community, improve the product, and communicate with users.</p>
                </div>
            </section>

            <section id="information" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">2. Information we collect</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>We may collect the following categories of information:</p>
                    <ul class="list-disc pl-5 space-y-2">
                        <li><span class="text-primary font-medium">Account information:</span> email address, display name, profile details, authentication state, password hash if you set a password, and sign-in timestamps.</li>
                        <li><span class="text-primary font-medium">Profile information:</span> name, bio, avatar, Twitter/X handle, LinkedIn handle, and other details you choose to add.</li>
                        <li><span class="text-primary font-medium">Submitted content:</span> product listings, startup ideas, categories, target customers, proposed prices, comments, votes, founder information, revenue ranges, pricing details, and related metadata.</li>
                        <li><span class="text-primary font-medium">Usage information:</span> pages visited, actions taken, votes submitted, dashboard activity, device/browser information, IP address, and basic diagnostic logs.</li>
                        <li><span class="text-primary font-medium">Communications:</span> messages you send to us, support requests, and email delivery events for sign-in or account-related messages.</li>
                    </ul>
                </div>
            </section>

            <section id="use" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">3. How we use information</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>We use information to:</p>
                    <ul class="list-disc pl-5 space-y-2">
                        <li>create and maintain accounts;</li>
                        <li>send magic links, authentication emails, service notices, and important account messages;</li>
                        <li>display directory listings, idea submissions, votes, comments, founder profiles, and validation metrics;</li>
                        <li>moderate content, prevent abuse, detect spam, and enforce our Terms of Service;</li>
                        <li>improve search, filters, ranking, recommendations, and product quality;</li>
                        <li>debug errors, monitor performance, secure the service, and comply with legal obligations.</li>
                    </ul>
                </div>
            </section>

            <section id="sharing" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">4. How information is shared</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>Public submissions may be visible to other users and visitors. This can include product names, idea titles, problem statements, target customers, proposed prices, founder names, public profile details, comments, vote counts, and validation signals.</p>
                    <p>We may share limited information with service providers that help us operate the website, such as hosting, database infrastructure, email delivery, analytics, security, and customer support tools. These providers may process information only as needed to provide services to us.</p>
                    <p>We may disclose information if required by law, to protect rights and safety, to investigate abuse, or as part of a merger, acquisition, financing, or sale of assets.</p>
                    <p>We do not sell your personal information.</p>
                </div>
            </section>

            <section id="cookies" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">5. Cookies and local storage</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>We use cookies and similar technologies to keep you signed in, protect sessions, remember preferences, and operate core website features. For example, authentication cookies may be used to maintain your signed-in session.</p>
                    <p>We may use local storage to remember interface preferences such as theme choice or sidebar state. You can clear cookies or local storage through your browser settings, but some features may stop working correctly.</p>
                </div>
            </section>

            <section id="retention" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">6. Data retention</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>We retain account information for as long as your account is active or as needed to provide the service. Public submissions may remain visible unless removed by you where supported, moderated by us, or deleted following a verified request.</p>
                    <p>Authentication tokens and session records may be retained for security, audit, and abuse-prevention purposes. We may keep certain records longer where required by law or necessary to resolve disputes, enforce agreements, or maintain platform integrity.</p>
                </div>
            </section>

            <section id="rights" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">7. Your choices and rights</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>Depending on where you live, you may have rights to access, correct, delete, restrict, object to, or receive a copy of certain personal information. You may also have the right to withdraw consent where processing is based on consent.</p>
                    <p>You can update some profile information directly in your account. For other privacy requests, contact us at the email address below. We may need to verify your identity before completing a request.</p>
                </div>
            </section>

            <section id="security" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">8. Security</h2>
                <div class="mt-3 space-y-3 text-13 leading-[1.7] text-secondary">
                    <p>We use reasonable technical and organizational measures to protect information, including secure authentication flows, hashed passwords when passwords are used, and limited access to operational systems.</p>
                    <p>No internet service is perfectly secure. You should protect your email account, avoid sharing sign-in links, and contact us if you believe your account or information has been compromised.</p>
                </div>
            </section>

            <section id="children" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">9. Children's privacy</h2>
                <p class="mt-3 text-13 leading-[1.7] text-secondary">WhoBuiltThis is not intended for children under 13, and we do not knowingly collect personal information from children under 13. If you believe a child has provided personal information, contact us and we will take appropriate steps.</p>
            </section>

            <section id="international" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">10. International users</h2>
                <p class="mt-3 text-13 leading-[1.7] text-secondary">Your information may be processed in countries other than where you live. Data protection laws may differ by location, but we will handle your information according to this policy.</p>
            </section>

            <section id="changes" class="scroll-mt-24 p-5 md:p-6 border-b border-default">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">11. Changes to this policy</h2>
                <p class="mt-3 text-13 leading-[1.7] text-secondary">We may update this Privacy Policy as the service changes. If we make material changes, we will make a reasonable effort to provide notice through the website or another appropriate channel.</p>
            </section>

            <section id="contact" class="scroll-mt-24 p-5 md:p-6">
                <h2 class="text-18 font-medium leading-[1.4] text-primary">12. Contact</h2>
                <p class="mt-3 text-13 leading-[1.7] text-secondary">
                    Privacy questions or requests can be sent to
                    <a href="mailto:hello@whoshippedit.com" class="text-link hover:underline">hello@whoshippedit.com</a>.
                </p>
                <p class="mt-4 text-11 leading-[1.5] text-tertiary">
                    This page is a practical starting point for a privacy policy and is not legal advice. Review it with qualified counsel before relying on it for production use.
                </p>
            </section>
        </article>
    </div>
</div>
